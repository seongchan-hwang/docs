            72,
            100
          ],
          "children": [
            {
              "type": "text",
              "id": "eaiSt",
              "name": "s3k",
              "fill": "#888888",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "SLIDE 3 · CLAIM",
              "fontFamily": "IBM Plex Mono",
              "fontSize": 24,
              "fontWeight": "500"
            },
            {
              "type": "text",
              "id": "nodW2",
              "name": "s3t",
              "fill": "#1A1A1A",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "오늘의 주장",
              "lineHeight": 1.08,
              "fontFamily": "Geist",
              "fontSize": 76,
              "fontWeight": "700"
            },
            {
              "type": "frame",
              "id": "QLJaa",
              "name": "s3d",
              "width": "fill_container",
              "height": 2,
              "fill": "#EEF0F2"
            },
            {
              "type": "text",
              "id": "EmUz7",
              "name": "s3b",
              "fill": "#1A1A1A",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "핵심 Bullet\n• Claude Code 강점은 단일 system prompt가 아니다\n• 긴 작업을 유지시키는 runtime engineering + tool architecture가 핵심\n• tool = 단순 외부 호출기 관점으로는 이 시스템을 설명할 수 없다",
              "lineHeight": 1.22,
              "fontFamily": "IBM Plex Mono",
              "fontSize": 29,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "Zr8fO",
              "name": "s3p",
              "fill": "#666666",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "발표자 포인트\n• 메시지는 단순한 \"tool이 중요하다\"가 아니다\n• business logic이 모델이 선택 가능한 행동 구조로 드러나는 지점이 핵심\n• 그 결과가 permission, reminder, artifact, runtime 상태로 연결된다",
              "lineHeight": 1.24,
              "fontFamily": "IBM Plex Mono",
              "fontSize": 26,
              "fontWeight": "normal"
            }
          ]
        },
