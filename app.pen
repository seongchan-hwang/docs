            100
          ],
          "children": [
            {
              "type": "text",
              "id": "fWrVI",
              "name": "s2k",
              "fill": "#888888",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "SLIDE 2 · WHY",
              "fontFamily": "IBM Plex Mono",
              "fontSize": 24,
              "fontWeight": "500"
            },
            {
              "type": "text",
              "id": "jrV6j",
              "name": "s2t",
              "fill": "#1A1A1A",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "왜 이걸 뜯어보는가",
              "lineHeight": 1.08,
              "fontFamily": "Geist",
              "fontSize": 76,
              "fontWeight": "700"
            },
            {
              "type": "frame",
              "id": "DCI6a",
              "name": "s2d",
              "width": "fill_container",
              "height": 2,
              "fill": "#EEF0F2"
            },
            {
              "type": "text",
              "id": "a6PtG",
              "name": "s2b",
              "fill": "#1A1A1A",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "핵심 Bullet\n• Harness Claude Code 분석으로 AX Platform 설계/개발/정책 판단 힌트 확보\n• Claude Code를 더 잘 활용하기 위해서도 내부 동작 이해가 필요\n• 본 발표는 source inspection 기반 working model",
              "lineHeight": 1.22,
              "fontFamily": "IBM Plex Mono",
              "fontSize": 29,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "rFGqS",
              "name": "s2p",
              "fill": "#666666",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "발표자 포인트\n• 엔지니어 audience에는 기능 데모보다 구조 해석이 더 가치 있다\n• 왜 잘 되는지 알면 우리 설계 의사결정으로 바로 번역할 수 있다",
              "lineHeight": 1.24,
              "fontFamily": "IBM Plex Mono",
              "fontSize": 26,
              "fontWeight": "normal"
            }
          ]
        },
        {
          "type": "frame",
          "id": "D7EJx",
          "name": "Slide 3",
          "width": 1920,
          "height": 1080,
          "fill": "#FFFFFF",
          "stroke": {
            "thickness": 1,
            "fill": "#EEF0F2"
          },
          "layout": "vertical",
          "gap": 22,
