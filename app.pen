              "content": "E2E에서 정말 중요한\n두 구간",
              "lineHeight": 1.08,
              "fontFamily": "Geist",
              "fontSize": 68,
              "fontWeight": "700"
            },
            {
              "type": "frame",
              "id": "YiQIk",
              "name": "s5d",
              "width": "fill_container",
              "height": 2,
